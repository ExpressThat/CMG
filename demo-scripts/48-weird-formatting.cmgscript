          setContent          "<main>{ready}<button id='run'>Run</button><output id='status'>Ready</output></main>"
if          true          {          caption          "inline if"          }          else          {          caption          "inline else"          }
          try          {          assertText          "#status"          "Ready"          }          catch          error          {          caption          "${error}"          }          finally          {          caption          "checked"          }
caption "semi;colon inside quotes"; caption "semicolon action separator"; if true { caption "nested;quote"; caption "nested separator" }
