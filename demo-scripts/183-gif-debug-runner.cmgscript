test "records frame diagnostics" {
  setContent "<style>html,body{margin:0;background:#fff}main{padding:48px;font:16px system-ui}button{font:inherit;padding:12px 18px}</style><main><h1>Runner diagnostics</h1><button id='run'>Run check</button><p id='status'>Ready</p></main>"
  step "Execute check" {
    click "#run"
    evaluate "document.querySelector('#status').textContent = 'Complete'"
    expectText "#status" "Complete"
  }
}
