test "records reduced-motion high-contrast evidence" {
  setContent "<style>html,body{margin:0;background:#fff}main{padding:48px;font:16px system-ui}button{font:inherit;padding:12px 18px;margin-right:18px}</style><main><h1>Runner pointer presets</h1><button id='first'>First action</button><button id='second'>Second action</button><p id='status'>Ready</p></main>"
  recording reducedMotion=true highContrastPointer=true {
    click "#first"
    click "#second" reducedMotion=false pointerDuration=260 pointerSize=50
    evaluate "document.querySelector('#status').textContent = 'Complete'"
    expectText "#status" "Complete"
  }
}
