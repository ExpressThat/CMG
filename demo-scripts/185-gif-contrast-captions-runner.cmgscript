test "records whole-run accessibility evidence" {
  setContent "<style>html,body{margin:0;background:#fff}main{padding:48px;font:16px system-ui}button{font:inherit;padding:12px 18px;color:#aaa;background:#f3f4f6;border:1px solid #ddd}</style><main><h1>Runner accessibility review</h1><button id='submit' aria-label='Submit review'>Submit</button><p id='status'>Ready</p></main>"
  step "Submit the review" {
    click "#submit"
    evaluate "document.querySelector('#status').textContent = 'Submitted'"
    expectText "#status" "Submitted"
  }
}
