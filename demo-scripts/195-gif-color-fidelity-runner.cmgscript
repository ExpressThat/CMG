test "records color fidelity" {
  setContent "<style>html{background:transparent}body{margin:0;background:transparent;font:16px system-ui}.panel{margin:32px;padding:28px;border-radius:8px;background:linear-gradient(120deg,rgba(14,165,233,.72),rgba(168,85,247,.78));box-shadow:0 18px 42px rgba(15,23,42,.24)}button{padding:12px 20px;background:#16a34a;color:white;border:0;border-radius:6px}</style><main class='panel'><h1>Runner color fidelity</h1><p>Whole-run color controls retain pointer-accurate evidence.</p><button id='confirm' onclick=\"this.textContent='Confirmed'\">Confirm</button></main>"
  click "#confirm"
  assertText "#confirm" "Confirmed"
}
