gif "long wait progress" output="demo-output/gif-long-wait-progress.gif" timeline=true coalesceDuplicates=false compressLongWaits=true longWaitThreshold=2000 longWaitDuration=1200 waitProgress=true {
  setContent "<style>html,body{margin:0;min-height:100%;background:#f8fafc}main{font:16px system-ui;padding:48px}</style><main><h1>Processing report</h1><p>A five-second logical hold remains concise visual evidence.</p></main>"
  pauseGif 5000
