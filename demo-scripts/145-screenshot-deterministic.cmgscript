# Freezes artifact-only animations and hides carets without changing GIF frames.
setContent "<main><style>@keyframes pulse{from{opacity:.3}to{opacity:1}} input{caret-color:red}.pulse{animation:pulse 1s infinite alternate}</style><h1 class='pulse'>Deterministic artifact</h1><input id='name' value='CMG'></main>"
caption "Screenshot artifact stabilization does not rewrite the live GIF view"
screenshotPage output="demo-output\screenshot-deterministic.png" animations=disabled caret=hide
screenshot "#name" output="demo-output\screenshot-deterministic-input.png" animations=disabled caret=hide
