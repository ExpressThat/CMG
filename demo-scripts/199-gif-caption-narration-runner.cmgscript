macro "work" { evaluate "document.querySelector('#status').textContent='Complete'" }
test "records nested caption narration" {
  recording persistentStepTitle=true sourceLineCaptions=true debugNarration=true captionFormat=markdown {
    setContent "<style>html,body{margin:0;min-height:100%;background:#fff}</style><main style='font:16px system-ui;padding:48px'><h1>Runner narration</h1><p id='status'>Ready</p></main>"
    step "**Checkout**" { step "Run `work` macro" { call "work" } }
    assertText "#status" "Complete"
  }
}
