test "captures masked screenshot evidence" {
  setContent "<main><h1>Masked screenshot evidence</h1><p id='clock'>Timestamp 12:34:56</p><p class='ad'>Sponsored content</p><button id='save'>Save</button></main>"
  caption "The artifact masks unstable regions; the GIF keeps the real page"
  screenshotPage output="demo-output\screenshot-mask-runner.png" mask="#clock;hasText=.ad|Sponsored" maskColor="#000000"
  screenshot "#save" output="demo-output\screenshot-mask-button-runner.png" mask="#clock" maskColor="#000000"
}
