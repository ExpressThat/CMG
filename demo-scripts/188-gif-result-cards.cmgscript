setContent "<style>html,body{margin:0;background:#fff}main{padding:48px;font:16px system-ui}button{font:inherit;padding:12px 18px}</style><main><h1>Checkout review</h1><button id='pay'>Pay now</button><p id='status'>Ready</p></main>"

gif "result cards" output="demo-output/gif-result-cards.gif" intro="Checkout verification" introDuration=800 resultOutro=true outroDuration=900 {
  click "#pay"
  evaluate "document.querySelector('#status').textContent = 'Paid'"
  expectText "#status" "Paid"
}
