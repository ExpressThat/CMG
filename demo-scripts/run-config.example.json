{
  "trace": "../demo-output/traces",
  "reportJson": "../demo-output/run-config-report.json",
  "reportHtml": "../demo-output/run-config-report.html",
  "grep": "config",
  "tag": "smoke",
  "retries": 1,
  "maxFailures": 2,
  "repeatEach": 1,
  "shard": "1/1",
  "timeout": 10000,
  "navigationTimeout": 15000,
  "assertionTimeout": 5000,
  "gifRetention": "onFailure",
  "gifSampleRate": 1,
  "gifCleanPassed": false,
  "gifSettings": {
    "quality": "highest",
    "pointerDuration": 500,
    "pointerSpeed": "normal",
    "fps": 10,
    "scale": 1,
    "captionStyle": "qa",
    "captionPosition": "auto",
    "autoCaptions": true,
    "captionTemplate": "{step}: {action} {selector}"
  },
  "projects": [
    {
      "name": "chrome-smoke",
      "browser": "chrome",
      "baseUrl": "https://example.test/chrome/",
      "tag": "smoke",
      "gifSettings": {
        "pointerSpeed": "fast",
        "frameDelay": 100
      },
      "variables": {
        "browserName": "chrome"
      }
    },
    {
      "name": "firefox-smoke",
      "browser": "firefox",
      "baseUrl": "https://example.test/firefox/",
      "tag": "smoke",
      "variables": {
        "browserName": "firefox"
      }
    }
  ],
  "variables": {
    "tenant": "demo",
    "mode": "config",
    "browserName": "default"
  }
}
