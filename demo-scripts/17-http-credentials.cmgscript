# Demonstrates page-side HTTP credential automation for fetch/XHR.

setHttpCredentials "agent" "secret"
route "/api/authenticated" status=200 body="ok" contentType="text/plain"
evaluate "fetch('/api/authenticated').then(response => response.text())"
waitForRequest "/api/authenticated" timeout=5000
waitForResponse "/api/authenticated" timeout=5000
clearHttpCredentials
clearRoutes
