test "frame block" {
  setContent "<main><iframe id='checkoutFrame'></iframe><script>const frame=document.querySelector('#checkoutFrame'); const doc=frame.contentDocument; doc.open(); doc.write(`<main><input id='email'><button id='save'>Save</button><p id='status'>Saved</p></main>`); doc.close();</script></main>"
  frame "#checkoutFrame" {
    waitForSelector "#email" timeout=5000
    fill "#email" "agent@example.com"
    click "#save"
    contains "Saved"
  }
}
