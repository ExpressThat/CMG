          describe          "inline formatting"          {          before          {          setContent          "<main>{ready}<button id='run'>Run</button><output id='status'>Ready</output></main>"; caption "setup;semicolon # quoted"          }          it          "handles inline blocks"          {          click #run
# inline comments can appear between dense blocks
if          true          {          caption          "inline # if"; caption "semicolon separator"          }          else          {          caption          "inline else"          }          try          {          assertText          "#status"          "Ready"          }          catch          error          {          caption          "${error}"          }          finally          {          caption          "checked"          }          }          }
