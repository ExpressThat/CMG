# Exercises custom validation messages on the sample form.
navigate "C:\Projects\CMG\index.html"
waitForElement "#projectSlug" timeout=5000

type "#projectSlug" "Bad Slug"
assertText "#projectSlugMessage" "Use lowercase words separated by single hyphens."

clear "#projectSlug"
type "#projectSlug" "cmg-browser-tools"
assertText "#projectSlugMessage" "Slug looks good."

type "#debugPort" "9222"
assertText "#debugPortMessage" "Port is in range."

type "#releaseNote" "Added a browser automation script demo."
assertText "#releaseNoteMessage" "Release note has enough detail."

screenshot "#validation" output="demo-output/validation-section.png"
