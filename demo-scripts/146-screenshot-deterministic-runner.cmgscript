test "captures deterministic screenshot evidence" {
  setContent "<main><style>@keyframes pulse{from{opacity:.3}to{opacity:1}} input{caret-color:red}.pulse{animation:pulse 1s infinite alternate}</style><h1 class='pulse'>Deterministic artifact</h1><input id='name' value='CMG'></main>"
  caption "Artifact stabilization is temporary; GIF frames stay faithful"
  screenshotPage output="demo-output\screenshot-deterministic-runner.png" animations=disabled caret=hide
  screenshot "#name" output="demo-output\screenshot-deterministic-input-runner.png" animations=disabled caret=hide
}
